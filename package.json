{
  "name": "claude-dev-sprite",
  "version": "0.1.0",
  "description": "Auto-detect Git commits and generate knowledge base docs",
  "main": "dist/worker/index.js",
  "bin": {
    "claude-dev-sprite": "dist/cli.js"
  },
  "files": [
    "dist/",
    "web/dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:web": "cd web && npm run build",
    "build:all": "npm run build:web && npm run build",
    "dev": "tsx --watch src/worker/index.ts",
    "start": "node dist/worker/index.js",
    "start:all": "npm run build:all && node dev-scripts/daemon.js restart",
    "test": "vitest",
    "daemon:start": "node dev-scripts/daemon.js start",
    "daemon:stop": "node dev-scripts/daemon.js stop",
    "daemon:status": "node dev-scripts/daemon.js status",
    "daemon:restart": "node dev-scripts/daemon.js restart",
    "prepublishOnly": "npm run build:all"
  },
  "keywords": [
    "git",
    "knowledge-base",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.1",
    "simple-git": "^3.23.0",
    "sql.js": "^1.11.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.4.0"
  }
}
